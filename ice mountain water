<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Ice Mountain Water Co delivers premium spring water in eco-conscious packaging for modern hydration." />
  <meta name="theme-color" content="#4f87ff" />
  <meta name="author" content="Ice Mountain Water Co" />
  <title>Ice Mountain Water Co</title>
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' fill='%234f87ff'/%3E%3Ctext x='50' y='60' font-size='44' font-family='Arial' text-anchor='middle' fill='white'%3EIM%3C/text%3E%3C/svg%3E" />
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <header class="site-header">
      <div class="brand">
<a href="https://www.icemountainwater.com/" target="_blank">
    <img src="images/ice-mountain-logo.png" alt="ICE MOUNTAIN Logo">
</a>      <div>
        <p class="eyebrow" data-i18n="brand_eyebrow">Ice Mountain Water Co</p>
        <h1 data-i18n="brand_h1">Pure refreshment from mountain springs.</h1>
      </div>
    </div>
    <button class="nav-toggle" aria-label="Open navigation" aria-expanded="false" type="button"><span></span></button>
    <nav class="site-nav" aria-label="Primary navigation">
      <a href="#about">About</a>
      <a href="#products">Products</a>
      <a href="#sustainability">Sustainability</a>
      <a href="#contact">Contact</a>
    </nav>
    <div class="header-actions">
      <button id="cartButton" class="btn cart-btn" aria-label="View cart">Cart (<span id="cartCount">0</span>)</button>
      <div id="langSwitcher" class="lang-switcher" aria-hidden="false">
        <button id="langEn" class="lang-btn" data-lang="en">EN</button>
        <button id="langAr" class="lang-btn" data-lang="ar">عربى</button>
      </div>
    </div>
  </header>

  <main>
    <section class="hero">
      <div class="hero-copy">
        <p class="hero-tag" data-i18n="hero_tag">Natural hydration crafted for modern living.</p>
        <h2 data-i18n="hero_h2">Refresh with clarity, renew with every sip.</h2>
        <p data-i18n="hero_p">We deliver premium mountain water in eco-conscious packaging designed for today’s active lifestyle.</p>
        <div class="hero-actions">
          <a id="heroShop" class="btn btn-primary" href="#products" data-i18n="hero_shop">Shop Bottled Water</a>
          <a id="heroContact" class="btn btn-ghost" href="#contact" data-i18n="hero_contact">Get in Touch</a>
        </div>
      </div>
      <aside class="hero-visual">
        <div style="display:flex;flex-direction:column;gap:1rem;">
          <div class="badge">100% Natural</div>
          <div class="glass-card">
            <p class="glass-title">About Ice Mountain</p>
            <p>Harvested from protected mountain springs, our water stays crisp and balanced from source to bottle.</p>
            <div style="margin-top:0.8rem;display:flex;gap:0.5rem;justify-content:flex-end">
              <a class="btn btn-primary" href="#products">Shop</a>
              <a class="btn btn-ghost" href="#contact">Contact</a>
            </div>
          </div>
        </div>
      </aside>
    </section>

    <section id="about" class="section split">
      <div>
        <p class="section-label" data-i18n="about_label">About Us</p>
        <h2 data-i18n="about_h2">From spring to shelf with a modern touch.</h2>
        <p data-i18n="about_p">Ice Mountain Water Co blends high-quality spring water with responsible packaging, supporting healthier lifestyles and a healthier planet.</p>
      </div>
      <div class="feature-grid">
        <article>
          <h3>Pure source</h3>
          <p>Mountain-fed springs are filtered by nature, giving our water a clean, crisp taste.</p>
        </article>
        <article>
          <h3>Balanced minerals</h3>
          <p>Every bottle delivers smooth hydration with light, natural minerals.</p>
        </article>
        <article>
          <h3>Modern packaging</h3>
          <p>Minimal design and recyclable materials keep your refreshment stylish and sustainable.</p>
        </article>
      </div>
    </section>

    <section id="products" class="section showcase">
      <p class="section-label" data-i18n="products_label">Products</p>
      <h2 data-i18n="products_h2">Hydration for every routine.</h2>
      <div class="filter-tabs" role="tablist" aria-label="Product filters">
        <button class="filter-btn active" data-filter="all">All</button>
        <button class="filter-btn" data-filter="mineral">Mineral Water</button>
        <button class="filter-btn" data-filter="sparkling">Sparkling Water</button>
      </div>
      <div class="card-grid" id="productGrid" aria-live="polite"></div>
    </section>

    <section id="sustainability" class="section highlight">
      <div class="highlight-content">
        <p class="section-label" data-i18n="sustainability_label">Sustainability</p>
        <h2 data-i18n="sustainability_h2">Good water, better for the earth.</h2>
        <p data-i18n="sustainability_p">We reduce waste with recyclable packaging, source from protected springs, and support local conservation efforts.</p>
      </div>
    </section>

    <section id="contact" class="section contact">
      <div>
        <p class="section-label" data-i18n="contact_label">Contact</p>
        <h2 data-i18n="contact_h2">Ready to elevate your hydration?</h2>
        <p data-i18n="contact_p">Reach out for wholesale orders, retail partnerships, or to learn more about our sustainability program.</p>
      </div>
      <a id="emailButton" class="btn btn-primary" href="mailto:IceMountainWater1@gmail.com" data-i18n="contact_email">Email Us</a>
    </section>

  </main>

  <footer class="footer">
    <p>&copy; <span id="footerYear">2026</span> Ice Mountain Water Co. Crafted for clear refreshment.</p>
  </footer>
  <script src="co.js"></script>
</body>
</html>
